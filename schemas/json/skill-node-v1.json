{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://graphskill.dev/schemas/skill-node-v1.json",
  "title": "Skill Node Schema",
  "description": "GraphSkill skill node data structure for graph database storage",
  "type": "object",
  "required": [
    "uid",
    "version",
    "intent_description",
    "permissions",
    "execution_success_rate",
    "is_deprecated",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "uid": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-z0-9_-]+$",
      "description": "Global unique skill identifier",
      "examples": ["git:commit_changes", "db:query_postgres"]
    },
    "embedding_id": {
      "type": "string",
      "description": "Associated vector database primary key"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
      "description": "Semantic version number (SemVer 2.0.0)",
      "examples": ["1.0.0", "2.1.3-beta"]
    },
    "intent_description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "LLM-oriented intent description"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]+:[a-z]+(:[a-zA-Z0-9_/-]+)?$"
      },
      "minItems": 1,
      "description": "Permission declaration list"
    },
    "trigger_conditions": {
      "type": "object",
      "description": "Trigger precondition assertions",
      "properties": {
        "env_vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "file_exists": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "service_available": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "execution_success_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 1.0,
      "description": "Historical execution success rate (EWMA decayed)"
    },
    "execution_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Historical execution count"
    },
    "is_deprecated": {
      "type": "boolean",
      "default": false,
      "description": "Soft delete flag"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Classification tags"
    },
    "author": {
      "type": "string",
      "description": "Author identifier"
    },
    "tenant_id": {
      "type": "string",
      "default": "default",
      "description": "Tenant identifier for multi-tenancy"
    }
  }
}